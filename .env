APP_NAME=NebulAuth
APP_ENV=production
APP_KEY=base64:kn4tcau0PGDEBPpF/G+u7UXOLGntDQ68SBlDg/aPXZs=
APP_DEBUG=false
APP_URL=https://auth.nebula.andrescortes.dev/

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=           # IP o dominio de tu VPS
DB_PORT=3306
DB_DATABASE=teatro_auth
DB_USERNAME=       # usuario MySQL
DB_PASSWORD=       # contraseña MySQL

JWT_SECRET=        # string largo y aleatorio, mismo en los 3 servicios
JWT_EXPIRATION=480 # minutos → 8 horas
JWT_ISSUER=https://auth.nebula.andrescortes.dev/

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=     # ejemplo: us-east-1
AWS_BUCKET=             # nombre de tu bucket
AWS_URL=                # URL pública del bucket
AWS_USE_PATH_STYLE_ENDPOINT=false

MONGO_URI=         # mongodb+srv://usuario:password@cluster.mongodb.net
MONGO_DATABASE=nebula_logs
MONGO_COLLECTION=logs_auth

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://auth.nebula.andrescortes.dev/api/auth/google/callback

N8N_WEBHOOK_URL=   # URL del webhook de n8n
N8N_SECRET=        # clave para que n8n sepa que el request viene de nosotros

FRONTEND_NEBULA_URL=https://nebula.andrescortes.dev/
FRONTEND_ADMIN_URL=https://admin.nebula.andrescortes.dev/
FRONTEND_TICKETS_URL=https://tickets.nebula.andrescortes.dev/
FRONTEND_ACCESS_URL=https://access.nebula.andrescortes.dev/

VITE_APP_NAME="${APP_NAME}"
